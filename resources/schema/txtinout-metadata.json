  "file_categories": {
    "master_config": ["file.cio", "codes.bsn", "parameters.bsn", "object.cnt", "time.sim", "print.prt", "object.prt"],
    "climate": ["weather-sta.cli", "weather-wgn.cli", "pcp.cli", "tmp.cli", "slr.cli", "hmd.cli", "wnd.cli", "atmo.cli"],
    "hru": ["hru-data.hru", "topography.hyd", "hydrology.hyd", "field.fld"],
    "soils": ["soils.sol"],
    "landuse": ["landuse.lum", "plant.ini", "management.sch", "cntable.lum", "cons_practice.lum", "ovn_table.lum"],
    "structural_practices": ["tiledrain.str", "septic.str", "filterstrip.str", "grassedww.str", "bmpuser.str"],
    "initialization": ["soil_plant.ini", "initial.aqu", "initial.cha", "initial.res", "om_water.ini", "pest_water.ini", "salt_water.ini", "path_water.ini", "hmet_water.ini", "snow.sno"],
    "aquifers": ["aquifer.aqu", "initial.aqu"],
    "channels": ["channel.cha", "initial.cha", "hydrology.cha", "sediment.cha", "nutrients.cha"],
    "reservoirs": ["reservoir.res", "initial.res", "hydrology.res", "sediment.res", "nutrients.res"],
    "wetlands": ["wetland.wet"],
    "routing": ["rout_unit.rtu", "rout_unit.def", "rout_unit.ele"],
    "databases": ["plants.plt", "fertilizer.frt", "pesticide.pes", "tillage.til", "urban.urb", "septic.sep"]
  },
  "common_pointer_patterns": {
    "init_pattern": {
      "description": "Files with 'init' field pointing to initialization files",
      "examples": [
        {"file": "aquifer.aqu", "field": "aqu_init", "target": "initial.aqu"},
        {"file": "reservoir.res", "field": "init", "target": "initial.res"},
        {"file": "channel.cha", "field": "init", "target": "initial.cha"}
      ]
    },
    "hyd_pattern": {
      "description": "Files with 'hyd' field pointing to hydrology parameter files",
      "examples": [
        {"file": "hru-data.hru", "field": "hydro", "target": "hydrology.hyd"},
        {"file": "reservoir.res", "field": "hyd", "target": "hydrology.res"},
        {"file": "channel.cha", "field": "hyd", "target": "hydrology.cha"}
      ]
    },
    "sed_pattern": {
      "description": "Files with 'sed' field pointing to sediment parameter files",
      "examples": [
        {"file": "reservoir.res", "field": "sed", "target": "sediment.res"},
        {"file": "channel.cha", "field": "sed", "target": "sediment.cha"}
      ]
    },
    "nut_pattern": {
      "description": "Files with 'nut' field pointing to nutrient parameter files",
      "examples": [
        {"file": "reservoir.res", "field": "nut", "target": "nutrients.res"},
        {"file": "channel.cha", "field": "nut", "target": "nutrients.cha"}
      ]
    },
    "constituent_init_pattern": {
      "description": "Initialization files with constituent pointers",
      "examples": [
        {"file": "initial.aqu", "field": "org_min", "target": "om_water.ini"},
        {"file": "initial.aqu", "field": "pest", "target": "pest_water.ini"},
        {"file": "initial.aqu", "field": "salt", "target": "salt_water.ini"}
      ]
    }
  }
}
